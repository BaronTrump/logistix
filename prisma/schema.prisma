generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Organizations (manufacturer + affiliates) ───
model Organization {
  id        String   @id @default(cuid())
  name      String
  type      OrgType  @default(MANUFACTURER)
  code      String   @unique
  domain    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  carriers   Carrier[]
  warehouses Warehouse[]
  shipments  Shipment[]
  drivers    Driver[]
  vehicles   Vehicle[]
  users      User[]
}

enum OrgType {
  MANUFACTURER
  AFFILIATE
  SUPPLIER
  LOGISTICS_PARTNER
}

// ─── Users ───
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  role           UserRole @default(VIEWER)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum UserRole {
  ADMIN
  LOGISTICS_MANAGER
  DISPATCHER
  VIEWER
}

// ─── Carriers ───
model Carrier {
  id             String   @id @default(cuid())
  name           String
  scac           String?  @unique
  mcNumber       String?
  mode           TransportMode
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  isActive       Boolean  @default(true)
  rating         Float?   @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vehicles  Vehicle[]
  shipments Shipment[]
}

enum TransportMode {
  TRUCK
  RAIL
  OCEAN
  AIR
  MULTIMODAL
}

// ─── Vehicles ───
model Vehicle {
  id             String        @id @default(cuid())
  carrierId      String
  carrier        Carrier       @relation(fields: [carrierId], references: [id])
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  type           VehicleType
  plate          String?
  vin            String?       @unique
  capacityKg     Float?
  capacityM3     Float?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())

  drivers    Driver[]
  shipments  Shipment[]
  positions  VehiclePosition[]
}

enum VehicleType {
  TRACTOR
  TRAILER
  STRAIGHT_TRUCK
  FLATBED
  REEFER
  TANKER
  BOXCAR
  CONTAINER_SHIP
  BULKER
  CARGO_PLANE
}

// ─── Vehicle Position (GPS pings) ───
model VehiclePosition {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  longitude Float
  latitude  Float
  speed     Float?
  heading   Float?
  recordedAt DateTime @default(now())
}

// ─── Drivers ───
model Driver {
  id             String   @id @default(cuid())
  name           String
  licenseNumber  String?
  phone          String?
  email          String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  carrierId      String?
  carrier        Carrier? @relation(fields: [carrierId], references: [id])
  vehicleId      String?
  vehicle        Vehicle? @relation(fields: [vehicleId], references: [id])
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
}

// ─── Warehouses / Facilities ───
model Warehouse {
  id             String   @id @default(cuid())
  name           String
  code           String   @unique
  type           WarehouseType @default(DISTRIBUTION)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  address        String?
  city           String
  state          String?
  country        String   @default("US")
  longitude      Float
  latitude       Float
  capacityM2     Float?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  originShipments      Shipment[] @relation("OriginWarehouse")
  destinationShipments Shipment[] @relation("DestinationWarehouse")
}

enum WarehouseType {
  MANUFACTURING
  DISTRIBUTION
  CROSS_DOCK
  RAW_MATERIAL
  FINISHED_GOODS
  FULFILLMENT
}

// ─── Customers ───
model Customer {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?
  city      String?
  state     String?
  country   String   @default("US")
  longitude Float?
  latitude  Float?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  shipments Shipment[]
}

// ─── Shipments ───
model Shipment {
  id                String        @id @default(cuid())
  shipmentNo        String        @unique
  organizationId    String
  organization      Organization  @relation(fields: [organizationId], references: [id])

  // Core
  status            ShipmentStatus @default(CREATED)
  priority          ShipmentPriority @default(NORMAL)

  // Origin / Destination
  originWarehouseId String?
  originWarehouse   Warehouse?    @relation("OriginWarehouse", fields: [originWarehouseId], references: [id])
  destWarehouseId   String?
  destWarehouse     Warehouse?    @relation("DestinationWarehouse", fields: [destWarehouseId], references: [id])

  // Customer (direct delivery)
  customerId        String?
  customer          Customer?     @relation(fields: [customerId], references: [id])

  // Carrier & Vehicle
  carrierId         String?
  carrier           Carrier?      @relation(fields: [carrierId], references: [id])
  vehicleId         String?
  vehicle           Vehicle?      @relation(fields: [vehicleId], references: [id])

  // Cargo
  description       String?
  weightKg          Float?
  volumeM3          Float?
  pieceCount        Int?
  hazmat            Boolean       @default(false)

  // Tracking
  estDeparture      DateTime?
  estArrival        DateTime?
  actualDeparture   DateTime?
  actualArrival     DateTime?
  transitMinutes    Int?

  // Route (GeoJSON-like)
  routeJson         Json?

  // Financial
  freightCharge     Float?
  currency          String        @default("USD")

  // Alerts
  isAtRisk          Boolean       @default(false)
  riskReason        String?

  // Metadata
  referenceNo       String?
  poNumber          String?
  bolNumber         String?
  notes             String?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  statusHistory     ShipmentStatusHistory[]
  alerts            Alert[]
}

enum ShipmentStatus {
  CREATED
  BOOKED
  PICKED_UP
  IN_TRANSIT
  AT_RISK
  DELAYED
  OUT_FOR_DELIVERY
  DELIVERED
  EXCEPTION
  CANCELLED
}

enum ShipmentPriority {
  RUSH
  HIGH
  NORMAL
  LOW
}

// ─── Shipment Status History ───
model ShipmentStatusHistory {
  id        String         @id @default(cuid())
  shipmentId String
  shipment  Shipment       @relation(fields: [shipmentId], references: [id])
  status    ShipmentStatus
  changedAt DateTime       @default(now())
  changedBy String?
  note      String?
}

// ─── Alerts ───
model Alert {
  id          String       @id @default(cuid())
  shipmentId  String?
  shipment    Shipment?    @relation(fields: [shipmentId], references: [id])
  type        AlertType
  severity    AlertSeverity @default(MEDIUM)
  title       String
  description String?
  location    String?
  acknowledged Boolean    @default(false)
  acknowledgedBy String?
  acknowledgedAt DateTime?
  createdAt   DateTime     @default(now())
}

enum AlertType {
  DELAY
  ROUTE_DEVIATION
  TEMPERATURE_BREACH
  HAZMAT_ISSUE
  CUSTOMER_COMPLAINT
  CAPACITY_ISSUE
  WEATHER_EVENT
  DOCUMENT_MISSING
  CARRIER_ISSUE
  CUSTOMS_HOLD
}

enum AlertSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}
